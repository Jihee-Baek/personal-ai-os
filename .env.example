# 데이터베이스 설정 (PostgreSQL)
# 로컬 개발 환경용 데이터베이스 주소 정보
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/personal_ai_os

# AI API 설정 (OpenRouter)
# OpenRouter API 키를 이곳에 입력하세요 (https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 깃허브 연동 설정
# GitHub Personal Access Token (PAT)을 이곳에 입력하세요
GITHUB_TOKEN=your_github_token_here

# 외부 서비스 API 키 (날씨 서비스용)
# OpenWeatherMap 등의 API 키를 이곳에 입력하세요
WEATHER_API_KEY=your_weather_api_key_here

# 프론트엔드 환경 변수
# 프론트엔드가 백엔드 API 서버를 가리킬 때 사용하는 주소입니다.
NEXT_PUBLIC_API_URL=http://localhost:8000
